# ─────────────────────────────────────────────────────────────────────────
# CallPilot backend configuration
#
# Fastest path to a working demo:
#   1. Fill in the three keys under "Core" below.
#   2. Run:  python scripts/provision_agents.py
#      → it creates the Caller + interview agents and prints the agent IDs.
#   3. Paste the printed ELEVENLABS_*_AGENT_ID values back here.
#   4. Leave CALL_MODE=simulation and you're ready — no Twilio, no webhook.
# ─────────────────────────────────────────────────────────────────────────

# ── Call mode ──────────────────────────────────────────────────────────────
# simulation = agent-to-agent via ElevenLabs' simulate-conversation (default;
#              no telephony, no Twilio, no public webhook). Genuine unscripted
#              negotiations with real transcripts and real price movement.
# telephony  = real outbound voice calls (needs the telephony vars below).
CALL_MODE=simulation

# ── Core (required in every mode) ──────────────────────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# Created for you by scripts/provision_agents.py:
ELEVENLABS_CALLER_AGENT_ID=

# ── Call-list sourcing (optional — "where the numbers come from") ──────────
# Tavily is preferred (uses a key you likely already have). Google Places is
# an alternative. With neither, enter the call list manually in the UI.
TAVILY_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Voice interview intake (optional) ──────────────────────────────────────
# Created by scripts/provision_agents.py (unless you pass --no-interview).
# Without it, the manual-form and document intake paths still work fully.
ELEVENLABS_INTERVIEW_AGENT_ID=

# ── Telephony only (ignored in simulation mode) ────────────────────────────
# The Twilio/SIP number registered in ElevenLabs that the Caller dials from:
ELEVENLABS_CALLER_PHONE_NUMBER_ID=
# OPTIONAL public URL for the log_quote webhook (real-time quote capture). Without
# it, quotes are still captured from the polled call transcript — so a local
# telephony demo needs only the phone-number id above, no ngrok/public URL:
WEBHOOK_BASE_URL=
# Phone numbers for the 3 telephony demo personas (see scripts/provision_agents.py
# --counterparties). Simulation drives these personas from their prompt files.
COUNTERPARTY_TOUGH_NUMBER=
COUNTERPARTY_STONEWALL_NUMBER=
COUNTERPARTY_HARDSELL_NUMBER=

# ── Model overrides (optional) ─────────────────────────────────────────────
# OpenAI models for vision extraction + report writing. Check current model
# names before a live run.
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o
# LLM the ElevenLabs agents run on (billed by ElevenLabs, not your OpenAI key).
# Must be enabled on your ElevenLabs plan.
ELEVENLABS_AGENT_LLM=gpt-4.1

# Comma-separated allowed CORS origins. "*" is fine for local/demo use.
CORS_ALLOW_ORIGINS=*
